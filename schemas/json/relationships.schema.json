{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polis.local/schemas/relationships.schema.json",
  "title": "Relationships",
  "description": "Single shared edge list (content/relationships.json) — the one place relationships are edited; no symmetric duplication.",
  "type": "object",
  "required": ["edges"],
  "additionalProperties": false,
  "properties": {
    "notes": {"type": "string"},
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["a", "b", "type", "closeness", "a_view", "b_view"],
        "additionalProperties": false,
        "properties": {
          "a": {"description": "agent id", "type": "string", "pattern": "^[a-z0-9_]+$"},
          "b": {"description": "agent id", "type": "string", "pattern": "^[a-z0-9_]+$"},
          "type": {"type": "string", "minLength": 1},
          "closeness": {
            "description": "interaction-propensity prior",
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "a_view": {"description": "seeds a's initial memory about b", "type": "string", "minLength": 1},
          "b_view": {"description": "seeds b's initial memory about a", "type": "string", "minLength": 1}
        }
      }
    }
  }
}
