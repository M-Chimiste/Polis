{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polis.local/schemas/town_spec.schema.json",
  "title": "TownSpec",
  "description": "Static town content (content/town.json). Generated once, frozen; the sim only reads this. Referential/geometric integrity beyond this schema is enforced by scripts/validate_content.py.",
  "type": "object",
  "required": ["id", "name", "grid", "locations", "occluders"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "name": {"type": "string", "minLength": 1},
    "grid": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      }
    },
    "description": {"type": "string"},
    "notes": {"type": "string"},
    "locations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/location"}
    },
    "occluders": {
      "type": "array",
      "items": {"$ref": "#/$defs/occluder"}
    }
  },
  "$defs": {
    "location": {
      "type": "object",
      "required": ["id", "name", "kind", "rect", "door", "privacy", "tags", "objects"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "name": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1},
        "rect": {
          "description": "[x, y, width, height] in grid cells",
          "type": "array",
          "items": {"type": "integer", "minimum": 0},
          "minItems": 4,
          "maxItems": 4
        },
        "door": {
          "description": "[x, y] door cell on the rect perimeter",
          "type": "array",
          "items": {"type": "integer", "minimum": 0},
          "minItems": 2,
          "maxItems": 2
        },
        "privacy": {
          "description": "0 = fully public, 1 = fully private (perception / social-norms hook)",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "tags": {"type": "array", "items": {"type": "string"}},
        "objects": {
          "description": "Objects-with-states: generic fixtures of a location, never personalized to an agent. interactions maps an allowed verb to the resulting state — the only way object state changes, and it is deterministic. affordances tag which needs the object can serve (grounding for the future needs system).",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "state", "interactions", "affordances"],
            "additionalProperties": false,
            "properties": {
              "id": {"description": "globally unique across the town", "type": "string", "pattern": "^[a-z0-9_]+$"},
              "name": {"description": "generic fixture name (e.g. 'Bed', 'Hearth'), not agent-owned", "type": "string", "minLength": 1},
              "state": {"type": "string", "pattern": "^[a-z0-9_]+$"},
              "interactions": {
                "type": "object",
                "minProperties": 1,
                "propertyNames": {"pattern": "^[a-z0-9_]+$"},
                "additionalProperties": {"type": "string", "pattern": "^[a-z0-9_]+$"}
              },
              "affordances": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"enum": ["sleep", "food", "hygiene", "leisure", "social", "work"]}
              }
            }
          }
        }
      }
    },
    "occluder": {
      "type": "object",
      "required": ["id", "at", "radius"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "at": {
          "type": "array",
          "items": {"type": "number", "minimum": 0},
          "minItems": 2,
          "maxItems": 2
        },
        "radius": {"type": "number", "exclusiveMinimum": 0},
        "note": {"type": "string"}
      }
    }
  }
}
